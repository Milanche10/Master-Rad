<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX 3 izvor za MSI instaler Android Forensic Dashboard-a.
  Pakuje PyInstaller izlaz (dist/AndroidForensicDashboard/) u .msi sa
  instalacionim carobnjakom, Start Menu + Desktop precicom i pravim uninstaller-om.

  WiX 3 trazi SAMO .NET Framework (postoji na svakom Windows-u) — NE .NET SDK.
  Build (build_installer.bat radi automatski):
    heat  dir dist\AndroidForensicDashboard -cg AppFiles -dr INSTALLFOLDER ... -var var.SourceDir -out installer\AppFiles.wxs
    candle -arch x64 -dSourceDir=<dist> -dProjectRoot=<root> installer\AFD.wxs installer\AppFiles.wxs
    light  -ext WixUIExtension AFD.wixobj AppFiles.wixobj -o dist\AndroidForensicDashboard-Setup.msi
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*"
           Name="Android Forensic Dashboard"
           Language="1033"
           Version="1.0.0.0"
           Manufacturer="Milan Jovanovic"
           UpgradeCode="6f3a9e2c-1b4d-4e7a-9c21-8a5b0d3f7e11">

    <Package InstallerVersion="500"
             Compressed="yes"
             InstallScope="perMachine"
             Manufacturer="Milan Jovanovic"
             Description="Android Forensic Dashboard - forenzicka analiza Android dump-ova" />

    <MajorUpgrade DowngradeErrorMessage="Novija verzija Android Forensic Dashboard-a je vec instalirana." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Ikonica aplikacije (Add/Remove Programs + precice) -->
    <Icon Id="AppIcon" SourceFile="$(var.ProjectRoot)\public\favicon.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />
    <Property Id="ARPHELPLINK" Value="https://github.com/Milanche10/Master-Rad" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/Milanche10/Master-Rad" />

    <!-- Ciljni direktorijumi -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="Android Forensic Dashboard" />
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="AppMenuDir" Name="Android Forensic Dashboard" />
      </Directory>
      <Directory Id="DesktopFolder" />
    </Directory>

    <!-- Feature: svi fajlovi aplikacije + precice -->
    <Feature Id="Main" Title="Android Forensic Dashboard" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

    <!-- Start Menu prečica -->
    <DirectoryRef Id="AppMenuDir">
      <Component Id="StartMenuShortcut" Guid="a1f2b3c4-0001-4a11-9b22-000000000001">
        <Shortcut Id="StartSc"
                  Name="Android Forensic Dashboard"
                  Description="Forenzicka analiza Android dump-ova"
                  Target="[INSTALLFOLDER]AndroidForensicDashboard.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="AppIcon" />
        <RemoveFolder Id="RemoveAppMenuDir" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\AndroidForensicDashboard"
                       Name="startmenu" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- Desktop prečica -->
    <DirectoryRef Id="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="a1f2b3c4-0002-4a11-9b22-000000000002">
        <Shortcut Id="DeskSc"
                  Name="Android Forensic Dashboard"
                  Description="Forenzicka analiza Android dump-ova"
                  Target="[INSTALLFOLDER]AndroidForensicDashboard.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="AppIcon" />
        <RegistryValue Root="HKCU" Key="Software\AndroidForensicDashboard"
                       Name="desktop" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- Instalacioni carobnjak (Welcome -> Licenca -> Folder -> Install) -->
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="$(var.ProjectRoot)\installer\license.rtf" />
    <UIRef Id="WixUI_InstallDir" />

  </Product>
</Wix>
